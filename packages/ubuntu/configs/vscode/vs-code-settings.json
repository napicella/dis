    ],
    "aws.suppressPrompts": {
        "remoteConnected": true
    },
    "remote.portsAttributes": {
        "443": {
            "protocol": "https"
        },
        "8443": {
            "protocol": "https"
        }
    },
    "remote.SSH.lockfilesInTmp": true,
    "remote.SSH.connectTimeout": 60,
    "remote.SSH.remotePlatform": {
        "aws-devenv-2a338861-54e4-4993-b969-bbc2fc02fe4f": "linux",
        "34.253.209.178": "windows",
        "winzoz": "windows"
    },
    "terminal.integrated.profiles.linux": {
        // Configures VS Code to use a login shell for the integrated terminal.
        // This ensures that the interactive terminal started by VS Code will
        // inherit environment variables set in your bashrc or zshrc files.
        // Ensure that your .bash_profile sources .bashrc, as that's where environment variables 
        // are typically defined or exported.
        //
        // Note that launch configs and tasks will NOT inherit env variables from the integrated terminal.
        // You need to set them in the launch/task config.
        "bash": {
            "path": "bash",
            "args": [
                "--login"
            ]
        },
        "zsh": {
            "path": "zsh"
        }
    },
    "terminal.integrated.defaultProfile.linux": "bash",
    "C_Cpp.clang_format_fallbackStyle": "Google",
    "files.autoSave": "afterDelay",
    "[go]": {
        "editor.insertSpaces": false,
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "cmake.showOptionsMovedNotification": false,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.fontFamily": "CaskaydiaMono Nerd Font",
    "aws.telemetry": false,
