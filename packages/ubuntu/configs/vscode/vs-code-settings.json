    "viceroy.doc.welcome.showAtStartup": false,
    "viceroy.config.setup.amazonQ": false,
    "viceroy.config.notifyGlibcIssue": false,
    "security.workspace.trust.untrustedFiles": "open",
    // settings for:
    // ext install streetsidesoftware.code-spell-checker
    "cSpell.languageSettings": [
        // GoLang settings        // Configures VS Code to use a login shell for the integrated terminal.
        // This ensures that the interactive terminal started by VS Code will
        // inherit environment variables set in your bashrc or zshrc files.
        // Ensure that your .bash_profile sources .bashrc, as that's where environment variables 
        // are typically defined or exported.
        //
        // Note that launch configs and tasks will NOT inherit env variables from the integrated terminal.
        // You need to set them in the launch/task config.
        {
            "languageId": "go",
            // Turn off compound words, because it is only checking strings.
            "allowCompoundWords": false,
            // Only check comments and strings
            "includeRegExpList": [
                "CStyleComment",
                "string"
            ],
            // Exclude imports, because they are also strings.
            "ignoreRegExpList": [
                // ignore mulltiline imports
                "import\\s*\\((.|[\r\n])*?\\)",
                // ignore single line imports
                "import\\s*.*\".*?\"",
                // ignore go generate directive
                "//\\s*go:generate.*",
                // ignore nolint directive
                "//\\s*nolint:.*"
            ]
        }
    ],
    "cSpell.userWords": [
        "moontide"
    ],
    "viceroy.workspaceSyncStrategy": "automatic",
    "cmake.pinnedCommands": [
        "workbench.action.tasks.configureTaskRunner",
        "workbench.action.tasks.runTask"
    ],
    "workbench.editor.enablePreview": false,
    "window.titleBarStyle": "custom",
    "editor.renderWhitespace": "all",
    "workbench.colorTheme": "Tokyo Night Storm",
    "amazonQ.telemetry": false,
    "update.mode": "none",
    "window.zoomLevel": 1,
    "workbench.settings.enableNaturalLanguageSearch": false,
    "workbench.commandPalette.experimental.enableNaturalLanguageSearch": false,
    "rewrap.wrappingColumn": 120,
    "editor.rulers": [
        120
    ],
    "diffEditor.hideUnchangedRegions.enabled": true
}